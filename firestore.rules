
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isSignedIn() {
      return request.auth != null;
    }

    /**
     * @description Controls access to user documents.
     * @path /users/{userId}
     * @allow (create) User with matching ID can create their document.
     * @allow (get, update, delete) Authenticated user can only access their own document.
     * @deny (create) User trying to create a document with a different ID.
     * @deny (list) Listing users is not allowed for general queries.
     * @principle Enforces document ownership for all operations.
     */
    match /users/{userId} {
      function isOwner() {
        return request.auth.uid == userId;
      }

      allow get, list: if isSignedIn();
      allow update: if isSignedIn() && isOwner();
      allow create: if isSignedIn() && isOwner();
      allow delete: if isSignedIn() && isOwner();
    }

    /**
     * @description Controls access to user profile documents.
     * @path /users/{userId}/profile/{profileId}
     * @allow (create) User with matching ID can create their profile document.
     * @allow (get) Any signed-in user can read another user's profile.
     * @allow (update, delete) Authenticated user can only access their own profile document.
     * @principle Public read for discoverability, owner-only write.
     */
    match /users/{userId}/profile/{profileId} {
       function isOwner() {
        return request.auth.uid == userId;
      }
      
      allow get: if isSignedIn();
      allow list: if false; // Disallow listing profiles directly.
      allow create: if isSignedIn() && isOwner();
      allow update: if isSignedIn() && isOwner();
      allow delete: if isSignedIn() && isOwner();
    }

    /**
     * @description Controls access to interest documents.
     * @path /interests/{interestId}
     * @allow (get, list) All authenticated users can read interests.
     * @deny (create, update, delete) Only authorized users can write interest document.
     * @principle Public read access with restricted write access.
     */
    match /interests/{interestId} {
      allow get, list: if true;
      allow create, update, delete: if false;
    }

     /**
      * @description Controls access to learning material documents.
      * @path /materials/{materialId}
      * @allow (get, list) All authenticated users can read learning materials.
      * @allow (create) Users can create learning materials with their UID in the uploadedBy field.
      * @allow (update, delete) Only the user who uploaded the material can update or delete it.
      * @deny (create) Creating a learning material with an uploadedBy field that doesn't match the user's UID.
      * @principle Public read, owner-only write for learning materials.
      */
    match /materials/{materialId} {
      allow get, list: if isSignedIn();

      allow create: if isSignedIn() && request.auth.uid == request.resource.data.uploadedBy;
      allow update: if isSignedIn() && request.auth.uid == resource.data.uploadedBy;
      allow delete: if isSignedIn() && request.auth.uid == resource.data.uploadedBy;
    }

    /**
     * @description Controls access to chat documents.
     * @path /chats/{chatId}
     * @allow (get, create) User can get or create a chat if they are a participant.
     * @principle Only participants can access chat metadata.
     */
    match /chats/{chatId} {
      function isParticipant() {
        return request.auth.uid in resource.data.participants;
      }
       function isCreatingParticipant() {
        return request.auth.uid in request.resource.data.participants;
      }

      allow get: if isSignedIn() && isParticipant();
      allow list: if isSignedIn(); // Allow listing chats for current user via array-contains
      allow create: if isSignedIn() && isCreatingParticipant();
      allow update: if isSignedIn() && isParticipant(); // For updating lastMessage etc.
    }

    /**
     * @description Controls access to messages within a chat.
     * @path /chats/{chatId}/messages/{messageId}
     * @allow (get, list, create) User can access messages if they are a participant of the parent chat.
     * @principle Inherits permissions from the parent chat document.
     */
    match /chats/{chatId}/messages/{messageId} {
      function isChatParticipant() {
        return request.auth.uid in get(/databases/$(database)/documents/chats/$(chatId)).data.participants;
      }
       function isSender() {
        return request.auth.uid == request.resource.data.senderId;
      }

      allow read, write: if isSignedIn() && isChatParticipant() && isSender();
      allow create: if isSignedIn() && isChatParticipant() && isSender();
      allow list, get: if isSignedIn() && isChatParticipant();
    }
  }
}
